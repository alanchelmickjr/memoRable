# =============================================
# MemoRable — Orin Nano 8GB Edge Configuration
# =============================================
# Battery-powered prototype. Every MB counts.
# 8GB unified RAM shared between CPU, GPU, OS.
#
# Memory budget (8GB unified — GPU shared with everything):
#   OS + JetPack/CUDA runtime:     ~1.5 GB
#   OAK-D DepthAI pipeline:        ~0.3 GB
#   AEC audio processing:           ~0.1 GB
#   Gemma 2 2B Q4 + LoRA:          ~1.5 GB
#   Hume preprocessing (face/voice): ~0.3 GB
#   MongoDB WiredTiger cache:        0.5 GB
#   Redis:                           0.25 GB
#   Node.js (MCP):                   0.5 GB
#   Headroom:                       ~3.0 GB

# ─── Application ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Tight Node.js heap — 512MB max (cgroup enforces 768MB total for process)
NODE_OPTIONS=--max-old-space-size=512

# ─── MongoDB (local, no auth for edge prototype) ─────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/memorable
# WiredTiger cache configured in mongod.conf: 512MB

# ─── Redis (local) ───────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
# maxmemory configured in redis-orin-nano.conf: 256MB

# ─── MCP Server ──────────────────────────────────────────────────────
TRANSPORT_TYPE=http
MCP_HTTP_PORT=8080
MCP_USER_ID=orin-nano-edge

# ─── Hume.ai — Emotion Sensing (PRIORITY for edge demo) ─────────────
# WebSocket streaming — lightweight, real-time emotion from mic/camera
HUME_API_KEY=${HUME_API_KEY}
HUME_ENDPOINT=wss://api.hume.ai/v0/stream/models

# Confidence thresholds — slightly relaxed for edge noise
HUME_FACE_MIN_CONFIDENCE=0.6
HUME_PROSODY_MIN_CONFIDENCE=0.5
HUME_LANGUAGE_MIN_CONFIDENCE=0.55

# Smaller chunks for battery — less buffering, faster response
HUME_MAX_CHUNK_DURATION=3000
HUME_STREAM_BUFFER_SIZE=3

# ─── Sensor Framework (edge sensors active) ──────────────────────────
ENABLE_CAMERA=true
ENABLE_MICROPHONE=true
ENABLE_GEOLOCATION=true

# ─── OAK-D Depth Camera (Luxonis DepthAI) ────────────────────────────
# Runs via DepthAI SDK — uses GPU for depth/spatial AI pipeline
# ~300MB GPU footprint
OAK_D_ENABLED=true
OAK_D_RESOLUTION=640x480
OAK_D_FPS=15
OAK_D_DEPTH_ENABLED=true
OAK_D_SPATIAL_AI=true

# ─── AEC (Acoustic Echo Cancellation) ────────────────────────────────
# Required for clean voice input when speakers are active
# ~100MB RAM footprint
AEC_ENABLED=true

# ─── Emotion Processing (tuned for edge latency) ─────────────────────
EMOTION_THRESHOLD=0.6
EMOTION_UPDATE_INTERVAL=3000
EMOTION_WEIGHTS_EVI=0.5
EMOTION_WEIGHTS_VIDEO=0.3
EMOTION_WEIGHTS_VOICE=0.2

# ─── Memory Windows (shorter for edge — faster context cycling) ──────
MEMORY_WINDOW_SHORT=600000     # 10 min (was 20)
MEMORY_WINDOW_MEDIUM=1800000   # 30 min (was 60)
MEMORY_WINDOW_LONG=43200000    # 12 hr  (was 24)

# ─── GPU / CUDA (Orin Nano — 1024 CUDA cores, Ampere) ────────────────
CUDA_VISIBLE_DEVICES=0
ENABLE_CUDA=1

# ─── Ollama (on-device inference with fine-tuned Gemma 2) ─────────────
# Gemma 2 2B + doc-to-LoRA: fine-tuned on MemoRable docs, memory patterns,
# salience model, Alan's preferences. The edge node thinks in MemoRable.
#
# LoRA adapter is tiny (~10-50MB). Base model Q4 quantized fits in ~1.5GB GPU.
# Total GPU footprint: ~1.6GB — leaves room for Hume preprocessing.
#
# Build the LoRA:  see edge/orin-nano/lora/README.md
# Create Modelfile: ollama create memorable-gemma2 -f Modelfile
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=memorable-gemma2
OLLAMA_BASE_MODEL=gemma2:2b
OLLAMA_LORA_PATH=/opt/memorable/lora/memorable-adapter

# ─── Video Processing (reduced for battery/memory) ───────────────────
VIDEO_MAX_RESOLUTION_WIDTH=640
VIDEO_MAX_RESOLUTION_HEIGHT=480
VIDEO_CHUNK_DURATION=3000
VIDEO_PROCESSING_INTERVAL=2000

# ─── Voice Processing ────────────────────────────────────────────────
VOICE_CHUNK_DURATION=3000
VOICE_MAX_DURATION=3600000     # 1 hr max (was 3)

# ─── Text Processing ─────────────────────────────────────────────────
TEXT_MAX_LENGTH=5000

# ─── Logging (minimal for disk/battery) ──────────────────────────────
LOG_LEVEL=warn
LOG_FORMAT=json

# ─── Rate Limiting (relaxed — single device, not public) ─────────────
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=200

# ─── Security ────────────────────────────────────────────────────────
# Edge device — local only, no external exposure
# Generate real keys before any network exposure
API_KEY=edge-prototype-local-only

# ─── Power Management ────────────────────────────────────────────────
# Custom vars for edge-aware behavior
EDGE_DEVICE=orin-nano-8gb
EDGE_BATTERY_AWARE=true
EDGE_LOW_POWER_THRESHOLD=20
# When battery < threshold: reduce sensor polling, skip non-critical processing
